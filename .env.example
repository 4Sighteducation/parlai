# OpenAI (server only — never expose to the browser)
OPENAI_API_KEY=

# Live voice session (Layer A — OpenAI Realtime API over WebRTC)
REALTIME_MODEL=gpt-realtime-2

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Supabase service role (server only — for route handlers)
SUPABASE_SERVICE_ROLE_KEY=

# Auth — configure one path in Supabase dashboard
# SSO (SAML): set your email domain, e.g. 4sighteducation.com
NEXT_PUBLIC_SSO_DOMAIN=
# OAuth fallback when SSO domain is unset: google | azure | apple
NEXT_PUBLIC_AUTH_PROVIDER=google

# Cheap text model for post-session analysis (Layer B)
ANALYSIS_MODEL=gpt-5.4-mini
